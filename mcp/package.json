{
  "name": "@arcaelas/mcp",
  "version": "3.0.0",
  "description": "Unified MCP server — RAG memory, image generation, audio, and AI tools",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "arko-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "start": "node dist/index.js",
    "inspector": "npx @modelcontextprotocol/inspector tsx src/index.ts"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "rag",
    "semantic-search",
    "embeddings",
    "vectra",
    "ollama",
    "openai",
    "image-generation",
    "text-to-speech"
  ],
  "author": {
    "name": "Miguel Guevara",
    "email": "arcaela.reyes@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/arcaelas/mcp"
  },
  "homepage": "https://github.com/arcaelas/mcp#readme",
  "bugs": {
    "url": "https://github.com/arcaelas/mcp/issues"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.3",
    "express": "^5.2.1",
    "vectra": "^0.12.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
